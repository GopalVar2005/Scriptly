# ============================================
# Scriptly — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (use MongoDB Atlas connection string for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/scriptly

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-64-char-string-here

# AI Services
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# YouTube Data API (optional — yt-dlp used as fallback)
YOUTUBE_API_KEY=your_youtube_api_key

# Server
PORT=5001
NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
# No trailing slashes!
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
